%% PawPal+ — final "as-built" class diagram
%% Reflects pawpal_system.py after the build (Plan renamed to Scheduler,
%% recurrence/status/filtering added). Compare with uml.mmd (initial design).
classDiagram
    class User {
        +int user_id
        +string full_name
        +string email
        +string account
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +check_conflicts(pet Pet, plan Scheduler, task Task) List~tuple~
        +add_task(pet Pet, plan Scheduler, task Task) tuple~bool,string~
        +edit_task(task Task) bool
        +delete_task(plan Scheduler, task Task) bool
        +all_tasks() List~Task~
        +filter_tasks(status string, pet_name string) List~Task~
    }

    class Pet {
        +int pet_id
        +string name
        +date date_of_birth
        +string species
        +List~Scheduler~ plans
        +add_plan(plan Scheduler) void
        +get_plan(day date) Optional~Scheduler~
        +all_tasks() List~Task~
    }

    class Scheduler {
        +date date
        +List~Task~ tasks
        +add_task(task Task) bool
        +has_conflict(task Task) bool
        +ordered_tasks() List~Task~
        +sort_by_time() List~Task~
    }

    class Task {
        +int task_id
        +string name
        +string start_time
        +int duration
        +string preferences
        +string priority
        +string status
        +string frequency
        +date due_date
        +mark_task_complete() Optional~Task~
        +end_time() string
        +overlaps(other Task) bool
    }

    User "1" o-- "0..*" Pet : owns
    Pet "1" *-- "0..*" Scheduler : has
    Scheduler "1" *-- "0..*" Task : schedules
    Task ..> Task : recurrence spawns next occurrence

    note for Scheduler "Renamed from 'Plan'. One per day. Enforces the 8am-5pm window and blocks overlapping tasks."
    note for Task "priority: high | medium | low. status: pending | complete. frequency: once | daily | weekly. Times are 'HH:MM' strings; due_date anchors recurrence."
    note for User "Orchestrates household-wide scheduling: check_conflicts and add_task inspect every pet's plan for that day. add_task returns an added-flag and a message."
